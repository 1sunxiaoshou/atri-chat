# ==========================================
# ATRI Chat 统一环境配置
# ==========================================

# 1. 运行模式设置 (Tauri客户端永远会覆盖并使用 production)
# development, production, staging
ENV=development

# 2. 纯服务器模式使用的端口通信配置 
# (Tauri客户端永远会覆盖并使用随机分配端口，所以这只对非Tauri端生效)
# 后端 API 服务器端口，前端也将默认同调尝试发向此端口
BACKEND_PORT=9099
FRONTEND_PORT=9900

# 3. 基础目录管理 (若注释，则默认在执行文件同级生成这些目录)
# DATA_DIR=data
# LOGS_DIR=logs
# ASR_MODELS_DIR=data/asr_models

# 4. 日志级别与分析
# TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
ENABLE_HTTP_LOGGING=true

# LLM 性能详细输出
ENABLE_LLM_CALL_LOGGER=false
