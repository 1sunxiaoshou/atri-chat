# ===== 环境配置 =====
# 运行环境: development, production, staging
# development - 开发环境：详细日志、彩色输出、完整堆栈
# production  - 生产环境：精简日志、结构化输出、敏感信息脱敏
# staging     - 测试环境：中等日志级别
ENV=development

# ===== 路径配置 =====
# 可选：自定义项目路径（留空则使用默认值）
# DATA_DIR=data
# LOGS_DIR=logs
# STATIC_DIR=static
# UPLOADS_DIR=data/uploads
# ASR_MODELS_DIR=asr_models

# ===== 日志配置 =====
# 日志级别: TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL
# 开发环境建议: DEBUG
# 测试环境建议: INFO
# 生产环境建议: WARNING
LOG_LEVEL=DEBUG

# LLM 调用日志记录器
# 启用后会详细记录所有 LLM 和工具调用的信息（提示词、响应、token 使用、耗时等）
# 用于调试和性能分析，生产环境建议关闭以提升性能
# 可选值: true, false
ENABLE_LLM_CALL_LOGGER=false

# HTTP 请求日志中间件
# 启用后会记录所有 HTTP 请求的信息（路径、状态码、耗时等）
# 用于访问日志和性能监控，生产环境可根据需要启用
# 可选值: true, false
ENABLE_HTTP_LOGGING=true
