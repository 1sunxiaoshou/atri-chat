# ==========================================
# ATRI Chat 统一环境配置
# ==========================================

# 1. 端口配置
# 后端监听端口（仅对源码直接启动后端时生效）
ATRI_BACKEND_PORT=9099
# 前端开发服务器默认代理到的后端端口
VITE_BACKEND_PORT=9099
# 前端开发服务器端口
FRONTEND_PORT=9900

# 2. 日志级别与分析
# TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
ENABLE_HTTP_LOGGING=true

# LLM 性能详细输出
ENABLE_LLM_CALL_LOGGER=false
